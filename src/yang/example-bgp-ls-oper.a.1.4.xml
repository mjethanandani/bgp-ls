<routing xmlns="urn:ietf:params:xml:ns:yang:ietf-routing"
 xmlns:bgp="urn:ietf:params:xml:ns:yang:ietf-bgp"
 xmlns:bgp-ls="urn:ietf:params:xml:ns:yang:ietf-bgp-ls"
 xmlns:t="urn:ietf:params:xml:ns:yang:ietf-bgp-ls-topo-types">
 <control-plane-protocols>
  <control-plane-protocol>
   <type>bgp:bgp</type>
   <name>example</name>
   <bgp:bgp>
    <bgp:global>
     <bgp:afi-safis>
      <bgp:afi-safi>
       <bgp:name>bgp-ls:bgp-ls</bgp:name>
       <bgp-ls:link-state>
        <bgp-ls-topology
         xmlns="urn:ietf:params:xml:ns:yang:ietf-bgp-ls">
         <instances>
          <instance>
           <vrf-name>default</vrf-name>
           <protocol>bgp</protocol>
           <identifier>0</identifier>
           <links>
            <bgp-link>
             <local-as>65001</local-as>
             <local-router-id>192.0.2.1</local-router-id>
             <remote-as>65002</remote-as>
             <remote-router-id>192.0.2.2</remote-router-id>
             <local-id>1</local-id>
             <remote-id>2</remote-id>
             <local-ipv4-address>198.51.100.1</local-ipv4-address>
             <remote-ipv4-address>198.51.100.2</remote-ipv4-address>
             <!-- :: sentinel: IPv4-only link -->
             <local-ipv6-address>::</local-ipv6-address>
             <remote-ipv6-address>::</remote-ipv6-address>
             <multi-topology-id>0</multi-topology-id>
             <link-attributes>
              <link-attribute>
               <type>t:bgp-ls-topo-attr-bgp-peer-adj-sid</type>
               <bgp-peer-sids>
                <bgp-peer-sid>
                 <label-index>100</label-index>
                 <format>label</format>
                 <!-- flags: 1 octet, all zeros -->
                 <flags>AA==</flags>
                 <weight>0</weight>
                </bgp-peer-sid>
               </bgp-peer-sids>
              </link-attribute>
             </link-attributes>
            </bgp-link>
           </links>
          </instance>
         </instances>
        </bgp-ls-topology>
       </bgp-ls:link-state>
      </bgp:afi-safi>
     </bgp:afi-safis>
    </bgp:global>
   </bgp:bgp>
  </control-plane-protocol>
 </control-plane-protocols>
</routing>
