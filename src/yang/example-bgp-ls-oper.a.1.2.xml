<routing xmlns="urn:ietf:params:xml:ns:yang:ietf-routing"
 xmlns:bgp="urn:ietf:params:xml:ns:yang:ietf-bgp"
 xmlns:bgp-ls="urn:ietf:params:xml:ns:yang:ietf-bgp-ls"
 xmlns:t="urn:ietf:params:xml:ns:yang:ietf-bgp-ls-topo-types">
 <control-plane-protocols>
  <control-plane-protocol>
   <type>bgp:bgp</type>
   <name>example</name>
   <bgp:bgp>
    <bgp:global>
     <bgp:afi-safis>
      <bgp:afi-safi>
       <bgp:name>bgp-ls:bgp-ls</bgp:name>
       <bgp-ls:link-state>
        <bgp-ls-topology
         xmlns="urn:ietf:params:xml:ns:yang:ietf-bgp-ls">
         <instances>
          <instance>
           <vrf-name>default</vrf-name>
           <protocol>ospfv3</protocol>
           <identifier>0</identifier>
           <nodes>
            <ospfv3-node>
             <is-as-scoped>false</is-as-scoped>
             <area-id>0.0.0.0</area-id>
             <router-id>192.0.2.1</router-id>
             <dr-identifier>0</dr-identifier>
             <as>65001</as>
             <node-attributes>
              <node-attribute>
               <type>t:bgp-ls-topo-attr-local-ipv6-routerid</type>
               <local-ipv6-router-ids>
                <router-id>2001:db8::1</router-id>
               </local-ipv6-router-ids>
              </node-attribute>
             </node-attributes>
            </ospfv3-node>
           </nodes>
           <links>
            <ospfv3-link>
             <area-id>0.0.0.0</area-id>
             <as>65001</as>
             <local-router-id>192.0.2.1</local-router-id>
             <local-dr-identifier>0</local-dr-identifier>
             <remote-router-id>192.0.2.2</remote-router-id>
             <remote-dr-identifier>0</remote-dr-identifier>
             <local-id>1</local-id>
             <remote-id>2</remote-id>
             <!-- 0.0.0.0 sentinel: IPv6-only link -->
             <local-ipv4-address>0.0.0.0</local-ipv4-address>
             <remote-ipv4-address>0.0.0.0</remote-ipv4-address>
             <local-ipv6-address>2001:db8::1</local-ipv6-address>
             <remote-ipv6-address>2001:db8::2</remote-ipv6-address>
             <multi-topology-id>0</multi-topology-id>
             <link-attributes>
              <link-attribute>
               <type>t:bgp-ls-topo-attr-igp-metric</type>
               <igp-metric><metric>10</metric></igp-metric>
              </link-attribute>
             </link-attributes>
            </ospfv3-link>
           </links>
           <prefixes>
            <ospfv3-prefix>
             <is-as-scoped>false</is-as-scoped>
             <area-id>0.0.0.0</area-id>
             <as>65001</as>
             <router-id>192.0.2.1</router-id>
             <dr-identifier>0</dr-identifier>
             <multi-topology-id>0</multi-topology-id>
             <route-type>intra-area</route-type>
             <prefix>2001:db8:1::/48</prefix>
            </ospfv3-prefix>
           </prefixes>
          </instance>
         </instances>
        </bgp-ls-topology>
       </bgp-ls:link-state>
      </bgp:afi-safi>
     </bgp:afi-safis>
    </bgp:global>
   </bgp:bgp>
  </control-plane-protocol>
 </control-plane-protocols>
</routing>
