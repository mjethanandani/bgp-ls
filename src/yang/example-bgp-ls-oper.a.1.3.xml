<routing xmlns="urn:ietf:params:xml:ns:yang:ietf-routing"
 xmlns:bgp="urn:ietf:params:xml:ns:yang:ietf-bgp"
 xmlns:bgp-ls="urn:ietf:params:xml:ns:yang:ietf-bgp-ls"
 xmlns:t="urn:ietf:params:xml:ns:yang:ietf-bgp-ls-topo-types">
 <control-plane-protocols>
  <control-plane-protocol>
   <type>bgp:bgp</type>
   <name>example</name>
   <bgp:bgp>
    <bgp:global>
     <bgp:afi-safis>
      <bgp:afi-safi>
       <bgp:name>bgp-ls:bgp-ls</bgp:name>
       <bgp-ls:link-state>
        <bgp-ls-topology
         xmlns="urn:ietf:params:xml:ns:yang:ietf-bgp-ls">
         <instances>
          <instance>
           <vrf-name>default</vrf-name>
           <protocol>isis-l1</protocol>
           <identifier>0</identifier>
           <nodes>
            <isis-node>
             <system-id>0000.0000.0001</system-id>
             <psn-id>0</psn-id>
             <as>65001</as>
             <node-attributes>
              <node-attribute>
               <type>t:bgp-ls-topo-attr-local-ipv4-routerid</type>
               <local-ipv4-router-ids>
                <router-id>192.0.2.1</router-id>
               </local-ipv4-router-ids>
              </node-attribute>
             </node-attributes>
            </isis-node>
           </nodes>
           <links>
            <isis-link>
             <local-system-id>0000.0000.0001</local-system-id>
             <local-psn-id>0</local-psn-id>
             <local-as>65001</local-as>
             <remote-system-id>0000.0000.0002</remote-system-id>
             <remote-psn-id>0</remote-psn-id>
             <remote-as>65001</remote-as>
             <local-id>1</local-id>
             <remote-id>2</remote-id>
             <local-ipv4-address>198.51.100.1</local-ipv4-address>
             <remote-ipv4-address>198.51.100.2</remote-ipv4-address>
             <!-- :: sentinel: IPv4-only link -->
             <local-ipv6-address>::</local-ipv6-address>
             <remote-ipv6-address>::</remote-ipv6-address>
             <multi-topology-id>0</multi-topology-id>
             <link-attributes>
              <link-attribute>
               <type>t:bgp-ls-topo-attr-igp-metric</type>
               <igp-metric><metric>10</metric></igp-metric>
              </link-attribute>
             </link-attributes>
            </isis-link>
           </links>
           <prefixes>
            <isis-prefix>
             <system-id>0000.0000.0001</system-id>
             <psn-id>0</psn-id>
             <as>65001</as>
             <multi-topology-id>0</multi-topology-id>
             <prefix>10.1.0.0/24</prefix>
            </isis-prefix>
           </prefixes>
          </instance>
         </instances>
        </bgp-ls-topology>
       </bgp-ls:link-state>
      </bgp:afi-safi>
     </bgp:afi-safis>
    </bgp:global>
   </bgp:bgp>
  </control-plane-protocol>
 </control-plane-protocols>
</routing>
